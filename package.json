{
  "name": "vite-plugin-sec-fetch-dest",
  "version": "0.1.1",
  "description": "Vite plugin that patches missing Sec-Fetch-Dest headers for IP/Safari access. Fixes TanStack Start + Nitro dev server module loading failures.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "tanstack-start",
    "nitro",
    "sec-fetch-dest",
    "safari",
    "dev-server"
  ],
  "author": "pildong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/babpulss/vite-plugin-sec-fetch-dest"
  },
  "bugs": {
    "url": "https://github.com/babpulss/vite-plugin-sec-fetch-dest/issues"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8",
    "typescript": "^5",
    "vite": "^8"
  }
}
